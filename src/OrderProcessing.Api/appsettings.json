{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=order_processing;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "OrderProcessing": {
    "PendingOrderThresholdMinutes": 15,
    "PendingOrderBatchSize": 100,
    "OrderCacheMinutes": 5
  },
  "Jwt": {
    "Issuer": "OrderProcessing",
    "Audience": "OrderProcessing.Client",
    "SigningKey": "development-only-signing-key-change-me-please"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
